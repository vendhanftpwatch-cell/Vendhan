rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: programs, coaches, events, gallery, updates, camps
    //   - Publicly readable, admin writable
    // Collection: bookings, registrations
    //   - User can create, read their own
    //   - Admin can read/write all
    // Collection: users
    //   - User can read/write their own (except role)
    //   - Admin can read/write all
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "vendhanftpwatch@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Collection Rules
    match /programs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coaches/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /updates/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /camps/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /registrations/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow create: if true; // Allow guest registrations
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
        (request.resource.data.role == 'user' || (request.auth.token.email == "vendhanftpwatch@gmail.com" && request.resource.data.role == 'admin'));
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }
  }
}
